# -----------------------------------------------------------------------------
# IFC source models (ifc, cypher, filesystem pipelines)
# -----------------------------------------------------------------------------

# Path to the ifc-bench `projects/` directory. Fetch it with
# `uv run scripts/download_data.py --with-models` (Hugging Face dataset
# sylvainHellin/ifc-bench), which symlinks it to data/ifc-bench/projects.
# IFC files are resolved as $IFC_BENCH_DIR/<project>/<ifc_model>.ifc.
# Relative paths are resolved against the repo root, regardless of where you run from.
IFC_BENCH_DIR=data/ifc-bench/projects

# Phoenix (Arize) OTEL trace storage. Local SQLite under this dir.
# Phoenix reads PHOENIX_WORKING_DIR from the environment (there is no CLI flag):
#   set -a; source .env; set +a; uv run phoenix serve
PHOENIX_WORKING_DIR=traces/

# -----------------------------------------------------------------------------
# LLM providers (set the ones you use)
# -----------------------------------------------------------------------------

# Default provider: MiniMax M2.7 (OpenAI-compatible, Token Plan)
# Model id: minimax:MiniMax-M2.7
MINIMAX_API_KEY=

# Fireworks AI (OpenAI-compatible)
FIREWORKS_API_KEY=

# Z.AI / GLM (OpenAI-compatible)
Z_AI_API_KEY=

# xAI / Grok (OpenAI-compatible)
XAI_API_KEY=

# Native providers (pass-through via langchain.init_chat_model)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# -----------------------------------------------------------------------------
# cypher pipeline (Neo4j)
# -----------------------------------------------------------------------------

# Connection used by pipelines/cypher/run.py. Defaults match
# pipelines/cypher/docker-compose.neo4j.yml.
NEO4J_BENCH_URI=bolt://localhost:7687
NEO4J_BENCH_USER=neo4j
NEO4J_BENCH_PASSWORD=bench_admin

# Password baked into the docker-compose Neo4j container (NEO4J_AUTH).
# Keep it in sync with NEO4J_BENCH_PASSWORD.
# docker compose does not read this file: export the variable in your shell
# (or pass --env-file) so `docker compose up` sees it.
NEO4J_ADMIN_PASSWORD=bench_admin
